-- StarterGui.GassyHub.Frame.Troll.Badges.LocalScript
local function C_66()
local script = G2L["66"];
	script.Parent.MouseButton1Up:Connect(function()
		
	
	
	
		local Players = game:GetService("Players")
		local ReplicatedStorage = game:GetService("ReplicatedStorage")
	
		local localPlayer = Players.LocalPlayer
	
		-- helpers
		local function getRoot(char)
			return char and char:FindFirstChild("HumanoidRootPart")
		end
	
		local function getHumanoid(char)
			return char and char:FindFirstChildOfClass("Humanoid")
		end
	
		-- MAIN ACTION
		local function react()
			local char = localPlayer.Character or localPlayer.CharacterAdded:Wait()
			local root = getRoot(char)
			local humanoid = getHumanoid(char)
			if not root or not humanoid then return end
	
			local morphRemote = ReplicatedStorage:WaitForChild("MorphEvent")
	
			-- save state
			local oldCF = root.CFrame
			local oldAnchored = root.Anchored
	
			-- STEP 1: go to void (no anchor yet)
			root.CFrame = CFrame.new(0, -250, 0)
	
			-- let it register
			task.wait(0.25)
	
			-- STEP 2: anchor AFTER arriving
			root.Anchored = true
	
			-- wait so server KNOWS you're there
			task.wait(1.2)
	
			-- STEP 3: fire FIRST morph (void)
			morphRemote:FireServer("Furcorn")
	
			-- give server time
			task.wait(1)
	
			-- STEP 4: unanchor before returning
			root.Anchored = false
	
			-- return
			root.CFrame = oldCF
	
			task.wait(0.5)
	
			-- STEP 5: fire SECOND morph
			morphRemote:FireServer("Dragong")
	
			-- restore anchor state
			root.Anchored = oldAnchored
		end
	
		-- debounce
		local debounce = false
	
		-- detect sit
		local function didPlayerSit(humanoid)
			for i = 1, 15 do
				task.wait(0.1)
				if humanoid and humanoid.Sit then
					return true
				end
			end
			return false
		end
	
		-- watch prompts
		local function watchPrompt(prompt)
			if not prompt:IsA("ProximityPrompt") then return end
			if not prompt.Parent or prompt.Parent.Name ~= "ClickTrigger" then return end
	
			task.spawn(function()
				while prompt.Parent do
					task.wait(0.2)
	
					if debounce then continue end
	
					local promptPart = prompt.Parent
					if not promptPart:IsA("BasePart") then continue end
	
					local promptPos = promptPart.Position
	
					for _, plr in pairs(Players:GetPlayers()) do
						if plr ~= localPlayer and plr.Character then
							local root = getRoot(plr.Character)
							local humanoid = getHumanoid(plr.Character)
	
							if root and humanoid then
								local dist = (root.Position - promptPos).Magnitude
	
								if dist < 10 then
									if didPlayerSit(humanoid) then
										debounce = true
										react()
										task.wait(2)
										debounce = false
										break
									end
								end
							end
						end
					end
				end
			end)
		end
	
		-- scan existing
		for _, obj in pairs(workspace:GetDescendants()) do
			watchPrompt(obj)
		end
	
		-- new prompts
		workspace.DescendantAdded:Connect(watchPrompt)
	
	
	
	end)
	
end;
task.spawn(C_66);
-- StarterGui.GassyHub.Frame.Troll.Badges.LocalScript
local function C_6a()
local script = G2L["6a"];
	script.Parent.MouseButton1Up:Connect(function()
		
		local Players = game:GetService("Players")
		local RS = game:GetService("ReplicatedStorage")
		local RunService = game:GetService("RunService")
	
		local player = Players.LocalPlayer
		local mouse = player:GetMouse()
	
		local remote = RS:WaitForChild("MorphEvent")
	
		-- UI
		local screenGui = Instance.new("ScreenGui")
		screenGui.Parent = player:WaitForChild("PlayerGui")
	
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 0, 50)
		label.BackgroundTransparency = 1
		label.TextScaled = true
		label.TextColor3 = Color3.fromRGB(255,255,255)
		label.Text = "You can force someone to adopt you and troll them"
		label.Parent = screenGui
	
		-- Anim IDs
		local hoverAnimId = "rbxassetid://110936244967206"
		local clickAnimId = "rbxassetid://105999250460625"
	
		local currentHighlight
		local currentTarget
		local hoverTrack
		local clickTrack
	
		-- Play animation helper
		local function playAnimation(animId)
			local char = player.Character
			if not char then return end
	
			local humanoid = char:FindFirstChildOfClass("Humanoid")
			if not humanoid then return end
	
			local anim = Instance.new("Animation")
			anim.AnimationId = animId
	
			local track = humanoid:LoadAnimation(anim)
			track.Looped = true
			track:Play()
	
			return track
		end
	
		-- Highlight helper
		local function setHighlight(char)
			if currentHighlight then
				currentHighlight:Destroy()
			end
	
			local h = Instance.new("Highlight")
			h.FillColor = Color3.fromRGB(0,0,255)
			h.OutlineColor = Color3.fromRGB(0,0,255)
			h.Adornee = char
			h.Parent = char
	
			currentHighlight = h
		end
	
		-- MAIN LOOP
		RunService.RenderStepped:Connect(function()
			local target = mouse.Target
			if not target then return end
	
			local char = target:FindFirstAncestorOfClass("Model")
			local plr = Players:GetPlayerFromCharacter(char)
	
			if plr and plr ~= player then
				if currentTarget ~= plr then
					currentTarget = plr
	
					-- 🔥 FIRE REMOTE FIRST (IMPORTANT)
					local args = {
						[1] = "Nitebear"
					}
					remote:FireServer(unpack(args))
	
					-- small delay to ensure server processes morph
					task.wait(0.1)
	
					-- THEN do everything else
					setHighlight(char)
	
					if hoverTrack then hoverTrack:Stop() end
					hoverTrack = playAnimation(hoverAnimId)
				end
			else
				-- reset
				currentTarget = nil
	
				if currentHighlight then
					currentHighlight:Destroy()
					currentHighlight = nil
				end
	
				if hoverTrack then
					hoverTrack:Stop()
					hoverTrack = nil
				end
			end
		end)
	
		-- CLICK
		local grabbing = false
		local grabConnection
	
		mouse.Button1Down:Connect(function()
			if not currentTarget then return end
	
			local targetChar = currentTarget.Character
			local myChar = player.Character
			if not targetChar or not myChar then return end
	
			local myRoot = myChar:FindFirstChild("HumanoidRootPart")
			local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
			if not myRoot or not targetRoot then return end
	
			-- 🔥 FIRE REMOTE FIRST
			local args = {
				[1] = "Nitebear"
			}
			remote:FireServer(unpack(args))
	
			task.wait(0.1)
	
			-- remove highlights
			for _, v in pairs(workspace:GetDescendants()) do
				if v:IsA("Highlight") then
					v:Destroy()
				end
			end
	
			-- stop old loop if exists
			if grabConnection then
				grabConnection:Disconnect()
			end
	
			grabbing = true
	
			-- 🔁 LOOP POSITION LOCK
			grabConnection = RunService.RenderStepped:Connect(function()
				if not grabbing then return end
				if not targetRoot.Parent or not myRoot.Parent then return end
	
				-- offset in front of target
				local offset = CFrame.new(0, 0, -2) -- change distance here
	
				local newCF = targetRoot.CFrame * offset
	
				-- force position
				myChar:PivotTo(newCF)
			end)
	
			-- switch animation
			if hoverTrack then hoverTrack:Stop() end
			if clickTrack then clickTrack:Stop() end
	
			clickTrack = playAnimation(clickAnimId)
		end)
	
	
	end)
	
end;
task.spawn(C_6a);
-- StarterGui.GassyHub.Frame.Troll.Badges.LocalScript
local function C_6e()
local script = G2L["6e"];
	script.Parent.MouseButton1Up:Connect(function()
		
		local Players = game:GetService("Players")
		local RS = game:GetService("ReplicatedStorage")
		local RunService = game:GetService("RunService")
	
		local player = Players.LocalPlayer
		local mouse = player:GetMouse()
	
		local remote = RS:WaitForChild("MorphEvent")
	
		-- UI
		local screenGui = Instance.new("ScreenGui")
		screenGui.Parent = player:WaitForChild("PlayerGui")
	
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 0, 50)
		label.BackgroundTransparency = 1
		label.TextScaled = true
		label.TextColor3 = Color3.fromRGB(255,255,255)
		label.Text = "Fwog Ride Script Enabled 🐸"
		label.Parent = screenGui
	
		-- Anim IDs
		local hoverAnimId = "rbxassetid://110936244967206"
		local rideAnimId = "rbxassetid://99496482278389"
	
		local currentTarget
		local hoverTrack
		local rideTrack
		local rideConnection
	
		-- Play animation helper
		local function playAnimation(animId)
			local char = player.Character
			if not char then return end
	
			local humanoid = char:FindFirstChildOfClass("Humanoid")
			if not humanoid then return end
	
			local anim = Instance.new("Animation")
			anim.AnimationId = animId
	
			local track = humanoid:LoadAnimation(anim)
			track.Looped = true
			track:Play()
	
			return track
		end
	
		-- MAIN TARGET DETECTION
		RunService.RenderStepped:Connect(function()
			local target = mouse.Target
			if not target then return end
	
			local char = target:FindFirstAncestorOfClass("Model")
			local plr = Players:GetPlayerFromCharacter(char)
	
			if plr and plr ~= player then
				if currentTarget ~= plr then
					currentTarget = plr
	
					-- 🔥 FIRE REMOTE (Fwog)
					remote:FireServer("Fwog")
	
					task.wait(0.1)
	
					if hoverTrack then hoverTrack:Stop() end
					hoverTrack = playAnimation(hoverAnimId)
				end
			else
				currentTarget = nil
	
				if hoverTrack then
					hoverTrack:Stop()
					hoverTrack = nil
				end
			end
		end)
	
		-- CLICK TO RIDE
		mouse.Button1Down:Connect(function()
			if not currentTarget then return end
	
			local targetChar = currentTarget.Character
			local myChar = player.Character
			if not targetChar or not myChar then return end
	
			local myRoot = myChar:FindFirstChild("HumanoidRootPart")
			local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
			if not myRoot or not targetRoot then return end
	
			-- 🔥 FIRE REMOTE AGAIN
			remote:FireServer("Fwog")
	
			task.wait(0.1)
	
			-- stop old loop
			if rideConnection then
				rideConnection:Disconnect()
			end
	
			-- stop hover anim
			if hoverTrack then hoverTrack:Stop() end
	
			-- play ride anim
			if rideTrack then rideTrack:Stop() end
			rideTrack = playAnimation(rideAnimId)
	
			-- LOOP: stay on target
			rideConnection = RunService.RenderStepped:Connect(function()
				if not targetRoot.Parent or not myRoot.Parent then return end
	
				-- position: slightly above + behind
				local offset = CFrame.new(0, 1.5, 1.5)
				local newCF = targetRoot.CFrame * offset
	
				myChar:PivotTo(newCF)
	
				-- slight forward push (on their back direction)
				targetRoot.Velocity = targetRoot.CFrame.LookVector * 8
			end)
		end)
	
	end)
	
end;
task.spawn(C_6e);
-- StarterGui.GassyHub.Frame.Troll.Badges.LocalScript
local function C_72()
local script = G2L["72"];
	script.Parent.MouseButton1Up:Connect(function()
		local Players = game:GetService("Players")
		local RS = game:GetService("ReplicatedStorage")
	
		local player = Players.LocalPlayer
		local remote = RS:WaitForChild("MorphEvent")
	
		-- 🔤 USER INPUT
		local message = script.Parent.TextBox.Text
	
		-- 🧠 LETTER → ANIMATION MAP
		local letterAnims = {
			A = "rbxassetid://140165407607929",
			B = "rbxassetid://139140056900110",
			C = "rbxassetid://102706636381416",
			D = "rbxassetid://119432455866325",
			E = "rbxassetid://126576517182219",
			F = "rbxassetid://135227259060683",
			G = "rbxassetid://71035736575796",
			H = "rbxassetid://128894072580927",
			I = "rbxassetid://139968424935712",
			J = "rbxassetid://110276817462232",
			K = "rbxassetid://120953677535193",
			L = "rbxassetid://129708137811096",
			M = "rbxassetid://98288662279156",
			N = "rbxassetid://102150051100984",
			O = "rbxassetid://140577652260082",
			P = "rbxassetid://101283801577322",
			Q = "rbxassetid://70764209868433",
			R = "rbxassetid://119295506247925",
			S = "rbxassetid://122443734972375",
			T = "rbxassetid://130055137342700",
			U = "rbxassetid://135824595429758",
			V = "rbxassetid://119340476183690",
			W = "rbxassetid://126908006538812",
			X = "rbxassetid://83068327805565",
			Y = "rbxassetid://121054460098923",
			Z = "rbxassetid://137589447206293"
		}
	
		-- 🎬 PLAY ANIMATION (FORCED)
		local function playAnim(animId, humanoid)
			local anim = Instance.new("Animation")
			anim.AnimationId = animId
	
			local track = humanoid:LoadAnimation(anim)
			track.Priority = Enum.AnimationPriority.Action4 -- 🔥 highest priority
			track.Looped = false
			track:Play()
	
			return track
		end
	
		-- 🔥 START
		remote:FireServer("PomPom")
	
		task.wait(0.4)
	
		local char = player.Character or player.CharacterAdded:Wait()
		local humanoid = char:WaitForChild("Humanoid")
	
		-- 🛑 DISABLE DEFAULT ANIMATIONS
		local animateScript = char:FindFirstChild("Animate")
		if animateScript then
			animateScript.Disabled = true
		end
	
		-- 🧊 FREEZE MOVEMENT (prevents walk/run overriding)
		local oldWalk = humanoid.WalkSpeed
		local oldJump = humanoid.JumpPower
	
		humanoid.WalkSpeed = 0
		humanoid.JumpPower = 0
		humanoid.AutoRotate = false
	
		-- ▶️ PLAY MESSAGE ONCE
		for letter in message:gmatch(".") do
			letter = letter:upper()
	
			local animId = letterAnims[letter]
			if animId then
				local track = playAnim(animId, humanoid)
	
				local length = track.Length
				task.wait(length > 0 and length or 0.5)
	
				track:Stop()
			else
				task.wait(0.3)
			end
		end
	
		-- 🔄 RETURN TO NORMAL
		if animateScript then
			animateScript.Disabled = false
		end
	
		humanoid.WalkSpeed = oldWalk
		humanoid.JumpPower = oldJump
		humanoid.AutoRotate = true
	
		-- optional: revert morph
		remote:FireServer("Normal")
	end)
end;
task.spawn(C_72);
-- StarterGui.GassyHub.Frame.Troll.Badges.LocalScript
local function C_78()
local script = G2L["78"];
	local Players = game:GetService("Players")
	local RS = game:GetService("ReplicatedStorage")
	local RunService = game:GetService("RunService")
	
	local player = Players.LocalPlayer
	local camera = workspace.CurrentCamera
	local remote = RS:WaitForChild("MorphEvent")
	
	remote:FireServer("Voidcorn")
	
	-- 🎬 ANIMS
	local triggerAnimId = "rbxassetid://129469072457859"
	local idleAnimId = "rbxassetid://115268975352566"
	local moveAnimId = "rbxassetid://100019669366103"
	
	local stareTime = 0
	local targetPlayer = nil
	local highlight = nil
	local triggered = false
	
	-- 🎨 highlight
	local function createHighlight(char)
		if highlight then highlight:Destroy() end
	
		local h = Instance.new("Highlight")
		h.FillTransparency = 0.5
		h.OutlineTransparency = 0
		h.Adornee = char
		h.Parent = char
	
		highlight = h
	end
	
	-- 🎬 anim
	local function playAnim(humanoid, id)
		local anim = Instance.new("Animation")
		anim.AnimationId = id
	
		local track = humanoid:LoadAnimation(anim)
		track.Priority = Enum.AnimationPriority.Action4
		track:Play()
	
		return track
	end
	
	-- 🔍 better "are we looking at them?"
	local function getLookTarget()
		local camPos = camera.CFrame.Position
		local lookVec = camera.CFrame.LookVector
	
		local bestPlayer = nil
		local bestDot = 0.97 -- tolerance (closer to 1 = stricter)
	
		for _, plr in pairs(Players:GetPlayers()) do
			if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
				local targetPos = plr.Character.HumanoidRootPart.Position
				local dir = (targetPos - camPos).Unit
	
				local dot = lookVec:Dot(dir)
	
				if dot > bestDot then
					bestDot = dot
					bestPlayer = plr
				end
			end
		end
	
		return bestPlayer
	end
	
	-- 🔁 LOOP
	RunService.RenderStepped:Connect(function(dt)
		if triggered then return end
	
		local plr = getLookTarget()
	
		if plr then
			if targetPlayer ~= plr then
				targetPlayer = plr
				stareTime = 0
				createHighlight(plr.Character)
			end
	
			stareTime += dt
	
			-- 🔴 color shift
			if highlight then
				local t = math.clamp(stareTime / 5, 0, 1)
				highlight.FillColor = Color3.new(1, 1 - t, 1 - t)
				highlight.OutlineColor = Color3.new(1, 0, 0)
			end
	
			-- ⏱ trigger
			if stareTime >= 5 then
				triggered = true
	
				local char = player.Character
				local humanoid = char:WaitForChild("Humanoid")
	
				local animate = char:FindFirstChild("Animate")
				if animate then animate.Disabled = true end
	
				-- freeze
				humanoid.WalkSpeed = 0
				humanoid.JumpPower = 0
				humanoid.AutoRotate = false
	
				-- play anim
				local track = playAnim(humanoid, triggerAnimId)
				task.wait(track.Length > 0 and track.Length or 2)
	
				-- restore animate
				if animate then
					animate.Disabled = false
	
					if animate:FindFirstChild("idle") then
						animate.idle.Animation1.AnimationId = idleAnimId
						animate.idle.Animation2.AnimationId = idleAnimId
					end
	
					if animate:FindFirstChild("walk") then
						animate.walk.WalkAnim.AnimationId = moveAnimId
					end
	
					if animate:FindFirstChild("run") then
						animate.run.RunAnim.AnimationId = moveAnimId
					end
				end
	
				-- 🚀 chase
				local targetChar = targetPlayer.Character
				local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
	
				if targetRoot then
					humanoid.WalkSpeed = 120
	
					RunService.RenderStepped:Connect(function()
						if not targetRoot.Parent then return end
	
						humanoid:MoveTo(targetRoot.Position)
					end)
				end
			end
	
		else
			-- reset
			targetPlayer = nil
			stareTime = 0
	
			if highlight then
				highlight:Destroy()
				highlight = nil
			end
		end
	end)
end;
task.spawn(C_78);
-- StarterGui.GassyHub.Frame.Troll.Badges.LocalScript
local function C_7c()
local script = G2L["7c"];
	script.Parent.MouseButton1Up:Connect(function()
		local Players = game:GetService("Players")
		local RS = game:GetService("ReplicatedStorage")
	
		local player = Players.LocalPlayer
		local remote = RS:WaitForChild("MorphEvent")
	
		local animId = "rbxassetid://137644260443394"
	
		-- 🔥 FIRE MORPH
		remote:FireServer("Mammott")
	
		task.wait(0.4)
	
		local char = player.Character or player.CharacterAdded:Wait()
		local humanoid = char:WaitForChild("Humanoid")
	
		-- 🛑 DISABLE Animate (not destroy, so movement still works better)
		local animate = char:FindFirstChild("Animate")
		if animate then
			animate.Disabled = true
		end
	
		-- 🧹 STOP ALL CURRENT ANIMS
		for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
			track:Stop()
		end
	
		-- 🎬 PLAY LOOPED ANIMATION
		local anim = Instance.new("Animation")
		anim.AnimationId = animId
	
		local track = humanoid:LoadAnimation(anim)
		track.Priority = Enum.AnimationPriority.Action4
		track.Looped = true
		track:Play()
	
		-- 🔒 KEEP IT DOMINANT (without freezing movement)
		task.spawn(function()
			while true do
				task.wait(0.3)
	
				if not track.IsPlaying then
					track:Play()
				end
	
				-- stop other animations BUT don't interfere with movement
				for _, t in pairs(humanoid:GetPlayingAnimationTracks()) do
					if t ~= track and t.Priority ~= Enum.AnimationPriority.Action4 then
						t:Stop()
					end
				end
			end
		end)
	end)
end;
task.spawn(C_7c);
-- StarterGui.GassyHub.Frame.Troll.Badges.LocalScript
local function C_80()
local script = G2L["80"];
	script.Parent.MouseButton1Up:Connect(function()
		local Players = game:GetService("Players")
		local RS = game:GetService("ReplicatedStorage")
		local RunService = game:GetService("RunService")
		local TweenService = game:GetService("TweenService")
	
		local player = Players.LocalPlayer
		local mouse = player:GetMouse()
		local remote = RS:WaitForChild("MorphEvent")
	
		local currentTarget
		local currentHighlight
	
		-- 🎨 highlight
		local function setHighlight(char)
			if currentHighlight then currentHighlight:Destroy() end
	
			local h = Instance.new("Highlight")
			h.FillColor = Color3.fromRGB(150, 0, 255)
			h.OutlineColor = Color3.fromRGB(150, 0, 255)
			h.Adornee = char
			h.Parent = char
	
			currentHighlight = h
		end
	
		-- 🔍 TARGET LOOP
		RunService.RenderStepped:Connect(function()
			local target = mouse.Target
			if not target then return end
	
			local char = target:FindFirstAncestorOfClass("Model")
			local plr = Players:GetPlayerFromCharacter(char)
	
			if plr and plr ~= player then
				if currentTarget ~= plr then
					currentTarget = plr
	
					remote:FireServer("Whisp")
					task.wait(0.1)
	
					setHighlight(char)
				end
			else
				currentTarget = nil
	
				if currentHighlight then
					currentHighlight:Destroy()
					currentHighlight = nil
				end
			end
		end)
	
		-- 👻 CLICK JUMPSCARE
		mouse.Button1Down:Connect(function()
			if not currentTarget then return end
	
			local myChar = player.Character
			local targetChar = currentTarget.Character
			if not myChar or not targetChar then return end
	
			local myRoot = myChar:FindFirstChild("HumanoidRootPart")
			local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
			if not myRoot or not targetRoot then return end
	
			remote:FireServer("Whisp")
			task.wait(0.1)
	
			-- 🔒 Freeze player to prevent flinging
			local wasAnchored = myRoot.Anchored
			myRoot.Anchored = true
	
			-- save original
			local originalCF = myRoot.CFrame
	
			-- remove highlight
			if currentHighlight then
				currentHighlight:Destroy()
			end
	
			-- 🎲 RANDOM OFFSET (unpredictable positioning)
			local randomOffset = Vector3.new(
				math.random(-6,6),
				math.random(10,16), -- higher above
				math.random(-6,6)
			)
	
			local startPos = targetRoot.Position + randomOffset
			local lookCF = CFrame.new(startPos, targetRoot.Position)
			myChar:PivotTo(lookCF)
	
			task.wait(0.15)
	
			-- 😈 TARGET FACE POSITION (slightly further out)
			local faceOffset = Vector3.new(0, 0, -3)
			local targetCF = targetRoot.CFrame * CFrame.new(faceOffset)
			targetCF = CFrame.new(targetCF.Position, targetRoot.Position)
	
			-- 🧲 TWEEN INTO FACE
			local tween = TweenService:Create(
				myRoot,
				TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{CFrame = targetCF}
			)
			tween:Play()
			tween.Completed:Wait()
	
			-- 😈 STICK TO FACE (3s)
			local duration = 3
			local start = tick()
	
			local connection
			connection = RunService.RenderStepped:Connect(function()
				if tick() - start >= duration then
					connection:Disconnect()
					return
				end
	
				if targetRoot.Parent then
					local cf = targetRoot.CFrame * CFrame.new(0, 0, -3)
					cf = CFrame.new(cf.Position, targetRoot.Position)
					myChar:PivotTo(cf)
				end
			end)
	
			task.wait(duration)
	
			-- 🔙 RETURN
			myChar:PivotTo(originalCF)
	
			-- 🔓 Unfreeze
			myRoot.Anchored = wasAnchored
		end)
	end)
end;
task.spawn(C_80);
