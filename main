-- StarterGui.GassyHub.Frame.Main.LocalScript
local function C_8()
local script = G2L["8"];
	local button = script.Parent
	local parentGui = button.Parent -- Assuming the button is in a Frame containing the ScrollFrames
	local buttonName = button.Name
	
	button.MouseButton1Click:Connect(function()
		-- Loop through all children of parentGui
		for _, child in ipairs(parentGui:GetChildren()) do
			-- Check if child is a ScrollingFrame
			if child:IsA("ScrollingFrame") then
				-- Make the ScrollFrame visible only if its name matches the button
				if child.Name == buttonName then
					child.Visible = true
				else
					child.Visible = false
				end
			end
		end
	end)
end;
task.spawn(C_8);
