local function WNOAXGA_fake_script() -- Badges_8.LocalScript 
	local script = Instance.new('LocalScript', Badges_8)

	script.Parent.MouseButton1Up:Connect(function()
		local function disableKillParts(obj)
			-- If it's a part, disable touch
			if obj:IsA("BasePart") then
				obj.CanTouch = false
				obj.Touched:Connect(function() end) -- override touch
			end
	
			-- Disable suspicious scripts
			if obj:IsA("Script") then
				local name = string.lower(obj.Name)
				if string.find(name, "kill") or string.find(name, "damage") or string.find(name, "lava") then
					obj.Disabled = true
				end
			end
		end
	
		-- Run on existing objects
		for _, obj in ipairs(workspace:GetDescendants()) do
			disableKillParts(obj)
		end
	
		-- Run on new objects added later
		workspace.DescendantAdded:Connect(function(obj)
			disableKillParts(obj)
		end)
	
		print("Anti-kill touch enabled")
	end)
end
coroutine.wrap(WNOAXGA_fake_script)()
