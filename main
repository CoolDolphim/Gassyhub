-- StarterGui.GassyHub.Frame.Automatic.Badges.LocalScript
local function C_93()
local script = G2L["93"];
	script.Parent.MouseButton1Up:Connect(function()
		local Players = game:GetService("Players")
		local player = Players.LocalPlayer
		local workspace = game:GetService("Workspace")
	
		local function getCharacter()
			return player.Character or player.CharacterAdded:Wait()
		end
	
		-- Fuzzy name check for "coin-like" folders
		local function isCoinRelated(name)
			name = name:lower()
	
			return name:find("coin") 
				or name:find("coien") 
				or name:find("coein") 
				or name == "co"
		end
	
		-- Get all CoinPickup objects (full scan + folder filtering)
		local function getAllCoins()
			local coins = {}
	
			for _, obj in pairs(workspace:GetDescendants()) do
				if obj.Name == "CoinPickup" then
					table.insert(coins, obj)
				elseif obj:IsA("Folder") and isCoinRelated(obj.Name) then
					for _, sub in pairs(obj:GetDescendants()) do
						if sub.Name == "CoinPickup" then
							table.insert(coins, sub)
						end
					end
				end
			end
	
			return coins
		end
	
		-- Get CFrame safely
		local function getCFrame(obj)
			if obj:IsA("BasePart") then
				return obj.CFrame
			elseif obj:IsA("Model") then
				if obj.PrimaryPart then
					return obj.PrimaryPart.CFrame
				else
					local part = obj:FindFirstChildWhichIsA("BasePart")
					if part then
						return part.CFrame
					end
				end
			end
		end
	
		-- Force chunks to load (StreamingEnabled support)
		local function loadAround(position)
			local char = getCharacter()
			local root = char:WaitForChild("HumanoidRootPart")
	
			-- move slightly toward area to trigger streaming load
			root.CFrame = CFrame.new(position + Vector3.new(0, 10, 0))
			task.wait(0.3)
		end
	
		-- Teleport loop
		local function teleportToCoins()
			local char = getCharacter()
			local root = char:WaitForChild("HumanoidRootPart")
	
			local coins = getAllCoins()
	
			for _, coin in pairs(coins) do
				local cf = getCFrame(coin)
	
				if cf then
					-- Ensure chunk loads
					loadAround(cf.Position)
	
					-- Final teleport
					root.CFrame = cf + Vector3.new(0, 3, 0)
					task.wait(0)
				end
			end
		end
	
		-- Run
		teleportToCoins()
	end)
end;
task.spawn(C_93);
