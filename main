local function OQVZDY_fake_script() -- Badges_11.LocalScript 
	local script = Instance.new('LocalScript', Badges_11)

	script.Parent.MouseButton1Up:Connect(function()
		
	
	
	
		local Players = game:GetService("Players")
		local ReplicatedStorage = game:GetService("ReplicatedStorage")
	
		local localPlayer = Players.LocalPlayer
	
		-- helpers
		local function getRoot(char)
			return char and char:FindFirstChild("HumanoidRootPart")
		end
	
		local function getHumanoid(char)
			return char and char:FindFirstChildOfClass("Humanoid")
		end
	
		-- MAIN ACTION
		local function react()
			local char = localPlayer.Character or localPlayer.CharacterAdded:Wait()
			local root = getRoot(char)
			local humanoid = getHumanoid(char)
			if not root or not humanoid then return end
	
			local morphRemote = ReplicatedStorage:WaitForChild("MorphEvent")
	
			-- save state
			local oldCF = root.CFrame
			local oldAnchored = root.Anchored
	
			-- STEP 1: go to void (no anchor yet)
			root.CFrame = CFrame.new(0, -250, 0)
	
			-- let it register
			task.wait(0.25)
	
			-- STEP 2: anchor AFTER arriving
			root.Anchored = true
	
			-- wait so server KNOWS you're there
			task.wait(1.2)
	
			-- STEP 3: fire FIRST morph (void)
			morphRemote:FireServer("Furcorn")
	
			-- give server time
			task.wait(1)
	
			-- STEP 4: unanchor before returning
			root.Anchored = false
	
			-- return
			root.CFrame = oldCF
	
			task.wait(0.5)
	
			-- STEP 5: fire SECOND morph
			morphRemote:FireServer("Dragong")
	
			-- restore anchor state
			root.Anchored = oldAnchored
		end
	
		-- debounce
		local debounce = false
	
		-- detect sit
		local function didPlayerSit(humanoid)
			for i = 1, 15 do
				task.wait(0.1)
				if humanoid and humanoid.Sit then
					return true
				end
			end
			return false
		end
	
		-- watch prompts
		local function watchPrompt(prompt)
			if not prompt:IsA("ProximityPrompt") then return end
			if not prompt.Parent or prompt.Parent.Name ~= "ClickTrigger" then return end
	
			task.spawn(function()
				while prompt.Parent do
					task.wait(0.2)
	
					if debounce then continue end
	
					local promptPart = prompt.Parent
					if not promptPart:IsA("BasePart") then continue end
	
					local promptPos = promptPart.Position
	
					for _, plr in pairs(Players:GetPlayers()) do
						if plr ~= localPlayer and plr.Character then
							local root = getRoot(plr.Character)
							local humanoid = getHumanoid(plr.Character)
	
							if root and humanoid then
								local dist = (root.Position - promptPos).Magnitude
	
								if dist < 10 then
									if didPlayerSit(humanoid) then
										debounce = true
										react()
										task.wait(2)
										debounce = false
										break
									end
								end
							end
						end
					end
				end
			end)
		end
	
		-- scan existing
		for _, obj in pairs(workspace:GetDescendants()) do
			watchPrompt(obj)
		end
	
		-- new prompts
		workspace.DescendantAdded:Connect(watchPrompt)
	
	
	
	end)
	
end
coroutine.wrap(OQVZDY_fake_script)()
local function UUZCR_fake_script() -- Badges_12.LocalScript 
	local script = Instance.new('LocalScript', Badges_12)

	script.Parent.MouseButton1Up:Connect(function()
		
		local Players = game:GetService("Players")
		local RS = game:GetService("ReplicatedStorage")
		local RunService = game:GetService("RunService")
	
		local player = Players.LocalPlayer
		local mouse = player:GetMouse()
	
		local remote = RS:WaitForChild("MorphEvent")
	
		-- UI
		local screenGui = Instance.new("ScreenGui")
		screenGui.Parent = player:WaitForChild("PlayerGui")
	
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 0, 50)
		label.BackgroundTransparency = 1
		label.TextScaled = true
		label.TextColor3 = Color3.fromRGB(255,255,255)
		label.Text = "You can force someone to adopt you and troll them"
		label.Parent = screenGui
	
		-- Anim IDs
		local hoverAnimId = "rbxassetid://110936244967206"
		local clickAnimId = "rbxassetid://105999250460625"
	
		local currentHighlight
		local currentTarget
		local hoverTrack
		local clickTrack
	
		-- Play animation helper
		local function playAnimation(animId)
			local char = player.Character
			if not char then return end
	
			local humanoid = char:FindFirstChildOfClass("Humanoid")
			if not humanoid then return end
	
			local anim = Instance.new("Animation")
			anim.AnimationId = animId
	
			local track = humanoid:LoadAnimation(anim)
			track.Looped = true
			track:Play()
	
			return track
		end
	
		-- Highlight helper
		local function setHighlight(char)
			if currentHighlight then
				currentHighlight:Destroy()
			end
	
			local h = Instance.new("Highlight")
			h.FillColor = Color3.fromRGB(0,0,255)
			h.OutlineColor = Color3.fromRGB(0,0,255)
			h.Adornee = char
			h.Parent = char
	
			currentHighlight = h
		end
	
		-- MAIN LOOP
		RunService.RenderStepped:Connect(function()
			local target = mouse.Target
			if not target then return end
	
			local char = target:FindFirstAncestorOfClass("Model")
			local plr = Players:GetPlayerFromCharacter(char)
	
			if plr and plr ~= player then
				if currentTarget ~= plr then
					currentTarget = plr
	
					-- 🔥 FIRE REMOTE FIRST (IMPORTANT)
					local args = {
						[1] = "Nitebear"
					}
					remote:FireServer(unpack(args))
	
					-- small delay to ensure server processes morph
					task.wait(0.1)
	
					-- THEN do everything else
					setHighlight(char)
	
					if hoverTrack then hoverTrack:Stop() end
					hoverTrack = playAnimation(hoverAnimId)
				end
			else
				-- reset
				currentTarget = nil
	
				if currentHighlight then
					currentHighlight:Destroy()
					currentHighlight = nil
				end
	
				if hoverTrack then
					hoverTrack:Stop()
					hoverTrack = nil
				end
			end
		end)
	
		-- CLICK
		local grabbing = false
		local grabConnection
	
		mouse.Button1Down:Connect(function()
			if not currentTarget then return end
	
			local targetChar = currentTarget.Character
			local myChar = player.Character
			if not targetChar or not myChar then return end
	
			local myRoot = myChar:FindFirstChild("HumanoidRootPart")
			local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
			if not myRoot or not targetRoot then return end
	
			-- 🔥 FIRE REMOTE FIRST
			local args = {
				[1] = "Nitebear"
			}
			remote:FireServer(unpack(args))
	
			task.wait(0.1)
	
			-- remove highlights
			for _, v in pairs(workspace:GetDescendants()) do
				if v:IsA("Highlight") then
					v:Destroy()
				end
			end
	
			-- stop old loop if exists
			if grabConnection then
				grabConnection:Disconnect()
			end
	
			grabbing = true
	
			-- 🔁 LOOP POSITION LOCK
			grabConnection = RunService.RenderStepped:Connect(function()
				if not grabbing then return end
				if not targetRoot.Parent or not myRoot.Parent then return end
	
				-- offset in front of target
				local offset = CFrame.new(0, 0, -2) -- change distance here
	
				local newCF = targetRoot.CFrame * offset
	
				-- force position
				myChar:PivotTo(newCF)
			end)
	
			-- switch animation
			if hoverTrack then hoverTrack:Stop() end
			if clickTrack then clickTrack:Stop() end
	
			clickTrack = playAnimation(clickAnimId)
		end)
	
	
	end)
	
end
coroutine.wrap(UUZCR_fake_script)()
